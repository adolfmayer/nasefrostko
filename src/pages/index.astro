---
import Layout from '../layouts/Layout.astro';
import { heroes } from '../data/heroes.js';
import { Crown, Coins } from 'lucide-astro';

interface Hero {
  id: string;
  name: string;
  image: string;
  color: string;
  borderColor: string;
}
---

<Layout title="Frosthaven Deník">
  <main class="max-w-6xl mx-auto py-12 px-4">
    <h1 class="font-medieval text-5xl text-white text-center mb-12 tracking-wider">
      Tvoje Parta
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {heroes.map((hero) => (
        <a 
          href={`/hero/${hero.id}`}
          class="hero-card group relative bg-zinc-900/50 rounded-3xl overflow-hidden border border-white/5 hover:border-neon-lime/30 transition-all duration-500"
          data-id={hero.id}
        >
          {/* Obrázek s overlayem */}
          <div class="aspect-4/5 overflow-hidden">
            <img 
              src={hero.image} 
              alt={hero.name} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-linear-to-t from-black via-black/20 to-transparent"></div>
          </div>

          {/* Obsah karty */}
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 p-6">
            <h2 class="font-medieval text-3xl text-white mb-1 group-hover:text-[oklch(0.75_0_0)] transition-colors">
              {hero.name}
            </h2>
            <p class="text-zinc-400 text-xs uppercase tracking-widest mb-4">{hero.race}</p>

            {/* LIVE STATS BAR */}
            <div class="flex items-center gap-4 py-3 px-4 bg-black/40 backdrop-blur-md rounded-2xl border border-white/5">
              <div class="flex items-center gap-1.5">
                <Crown class="w-4 h-4 text-yellow-500" />
                <span class="text-sm font-bold text-white" id={`lvl-${hero.id}`}>1</span>
              </div>
              
              <div class="w-px h-4 bg-white/10"></div>

              <div class="flex items-center gap-1.5">
                <Coins class="w-4 h-4 text-amber-400" />
                <span class="text-sm font-bold text-white" id={`gold-${hero.id}`}>0</span>
              </div>
              
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../supabase.js';

  async function updateDashboard() {
    // 1. Nejdřív zkusíme načíst VŠECHNA data hrdinů najednou ze Supabase
    console.log('Načítám přehled hrdinů z cloudu...');
    const { data: cloudData, error } = await supabase
      .from('hero_stats')
      .select('hero_id, level, gold');

    if (error) {
      console.error('Chyba při načítání cloudu:', error.message);
    }

    // 2. Najdeme všechny karty hrdinů na stránce
    const cards = document.querySelectorAll('.hero-card');

    cards.forEach(card => {
      const id = card.getAttribute('data-id');
      if (!id) return;

      let currentLvl = 1;
      let currentGold = 0;

      // A. Priorita: Podíváme se, jestli máme data z cloudu pro tohoto hrdinu
      const heroStats = cloudData?.find(h => h.hero_id === id);
      
      if (heroStats) {
        currentLvl = heroStats.level;
        currentGold = heroStats.gold;
      } 
      // B. Fallback: Pokud cloud nic nevrátil, zkusíme localStorage (pro jistotu)
      else {
        // Načtení Levelu z localu
        for (let i = 1; i <= 9; i++) {
          if (localStorage.getItem(`${id}-level-${i}`) === 'true') {
            currentLvl = i;
          }
        }
        // Načtení Goldů z localu
        currentGold = parseInt(localStorage.getItem(`${id}-gold`) || '0');
      }

      // 3. Vepíšeme data do HTML prvků karty
      const lvlEl = document.getElementById(`lvl-${id}`);
      if (lvlEl) lvlEl.textContent = currentLvl.toString();

      const goldEl = document.getElementById(`gold-${id}`);
      if (goldEl) goldEl.textContent = currentGold.toString();
    });
  }

  // Spustit při načtení
  updateDashboard();
  
  // Pro Astro View Transitions
  document.addEventListener('astro:after-swap', updateDashboard);
</script>